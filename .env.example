# Supply Chain Sentinel — Environment Configuration Template
# Copy this file to '.env' and fill in your API keys.

# Google Gemini API Key (Required for AI Intent Analysis)
# Supports comma-separated multiple keys for rotation: KEY1,KEY2,KEY3
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Override default Gemini model (default: gemini-3.5-flash)
# SENTINEL_AI_MODEL=gemini-3.5-flash

# Optional Threat Intelligence APIs
# ABUSEIPDB_API_KEY=your_abuseipdb_key_here
# VIRUSTOTAL_API_KEY=your_virustotal_key_here
