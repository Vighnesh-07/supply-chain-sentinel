# ═══════════════════════════════════════════════════════════════
# Supply Chain Sentinel — .gitignore
# ═══════════════════════════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# ── Secrets & Environment Variables ──
.env
.env.*
*.env
secrets/
*.key
*.pem

# ── Generated Reports & Presentations ──
reports/*.xlsx
reports/*.xls
*.pptx

# ── SBOM Artifacts ──
monitor/sbom.json
*.sbom.json

# ── ML Models (Phase 3) ──
ml/models/*.pkl
ml/models/*.joblib

# ── Captured Data (Phase 3) ──
data/*.pcap
data/*.csv

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ──
*.log

# ── Node.js ──
node_modules/
**/node_modules/

# ── Sentinel ──
malware_quarantine/
monitor/reports/
